---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { getSpecSections, type SpecSection, type SpecTocEntry } from "@/lib/spec-content";

export function getStaticPaths() {
  const sections = getSpecSections();
  return sections.map((sec, i) => ({
    params: { section: sec.slug },
    props: { section: sec, index: i, allSections: sections },
  }));
}

interface Props {
  section: SpecSection;
  index: number;
  allSections: SpecSection[];
}

const { section, index, allSections } = Astro.props;

const prev = index > 0 ? allSections[index - 1] : null;
const next = index < allSections.length - 1 ? allSections[index + 1] : null;

const localToc = section.toc.filter((e: SpecTocEntry) => e.level === 3 || e.level === 4);
---

<Layout title={`${section.number ? section.number + '. ' : ''}${section.title} — Agent Auth Protocol`} bodyClass="spec-page-body" darkMode>
  <Nav active="/specification" />

  <div class="spec-sections-shell">
    <!-- Left sidebar: section navigation -->
    <aside class="spec-sidebar-left" id="spec-sidebar-left">
      <nav aria-label="Specification sections">
        <div class="spec-sidebar-header">
          <span class="spec-sidebar-label">Specification</span>
          <span class="spec-sidebar-version">v1.0-draft</span>
        </div>
        <ul class="spec-sidebar-list">
          {allSections.map((sec) => (
            <li>
              <a
                href={`/specification/${sec.slug}`}
                class:list={["spec-sidebar-link", { active: sec.slug === section.slug }]}
              >
                {sec.number ? `${sec.number}. ` : ''}{sec.title}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <!-- Main content -->
    <div class="spec-sections-content" id="spec-scroll-container">
      <article class="spec-content-area">
        <div class="spec-content" data-pagefind-body set:html={section.html} />

        <!-- Prev/next navigation -->
        <div class="spec-prev-next">
          {prev && (
            <a href={`/specification/${prev.slug}`} class="spec-prev-next-link spec-prev">
              <span class="spec-prev-next-label">Previous</span>
              <span class="spec-prev-next-title">{prev.number ? `${prev.number}. ` : ''}{prev.title}</span>
            </a>
          )}
          {next && (
            <a href={`/specification/${next.slug}`} class="spec-prev-next-link spec-next">
              <span class="spec-prev-next-label">Next</span>
              <span class="spec-prev-next-title">{next.number ? `${next.number}. ` : ''}{next.title}</span>
            </a>
          )}
        </div>
      </article>
      <Footer />
    </div>

    <!-- Right sidebar: local TOC -->
    {localToc.length > 0 && (
      <aside class="spec-sidebar-right">
        <nav aria-label="On this page">
          <div class="spec-sidebar-header">
            <span class="spec-sidebar-label">On this page</span>
          </div>
          <ul class="spec-local-toc">
            {localToc.map((entry: SpecTocEntry) => (
              <li>
                <a
                  href={`#${entry.id}`}
                  class:list={["spec-local-toc-link", { "spec-local-toc-sub": entry.level === 4 }]}
                  data-toc-id={entry.id}
                >
                  {entry.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}
  </div>

  <!-- Mobile sidebar toggle -->
  <button id="spec-sidebar-toggle" class="spec-sidebar-toggle" aria-label="Toggle section navigation">
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>

  <!-- Floating controls -->
  <div class="fixed bottom-5 right-5 z-50 flex items-center border border-[var(--color-border)] bg-[var(--color-bg)] rounded-full shadow-sm">
    <button
      id="spec-search-trigger"
      class="h-9 w-9 flex items-center justify-center text-[var(--color-muted)] hover:text-[var(--color-fg)] transition-colors cursor-pointer"
      aria-label="Search specification"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    </button>
    <div class="w-px h-4 bg-[var(--color-border)]"></div>
    <button
      id="theme-toggle"
      class="h-9 w-9 flex items-center justify-center text-[var(--color-muted)] hover:text-[var(--color-fg)] transition-colors cursor-pointer"
      aria-label="Toggle theme"
    >
      <svg class="h-4 w-4 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg class="h-4 w-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
  </div>

  <script is:inline>
    document.getElementById("theme-toggle")?.addEventListener("click", function() {
      var isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });

    // Mobile sidebar toggle
    document.getElementById("spec-sidebar-toggle")?.addEventListener("click", function() {
      document.getElementById("spec-sidebar-left")?.classList.toggle("open");
    });

    // Active heading tracking
    (function() {
      var container = document.getElementById("spec-scroll-container");
      if (!container) return;

      var headings = container.querySelectorAll("h3[id], h4[id]");
      var tocLinks = document.querySelectorAll("[data-toc-id]");
      var tocMap = new Map();
      tocLinks.forEach(function(link) { tocMap.set(link.getAttribute("data-toc-id"), link); });

      var internalLinks = document.querySelectorAll('.spec-content a[href^="#"], [data-toc-id][href^="#"]');

      function setActive(activeId) {
        tocLinks.forEach(function(link) { link.classList.remove("active"); });
        var activeLink = tocMap.get(activeId);
        if (activeLink) activeLink.classList.add("active");
      }

      function scrollToHeading(id, behavior) {
        var el = document.getElementById(id);
        if (!el) return;
        var containerRect = container.getBoundingClientRect();
        var elRect = el.getBoundingClientRect();
        var offset = elRect.top - containerRect.top + container.scrollTop - 24;
        container.scrollTo({ top: offset, behavior: behavior || "smooth" });
        setActive(id);
        window.history.replaceState(null, "", "#" + id);
      }

      var observer = new IntersectionObserver(
        function(entries) {
          var visible = entries.filter(function(e) { return e.isIntersecting; });
          if (visible.length > 0) {
            visible.sort(function(a, b) { return a.boundingClientRect.top - b.boundingClientRect.top; });
            setActive(visible[0].target.id);
          }
        },
        { root: container, rootMargin: "-20px 0px -65% 0px", threshold: 0 }
      );

      headings.forEach(function(h) { observer.observe(h); });

      internalLinks.forEach(function(link) {
        link.addEventListener("click", function(e) {
          e.preventDefault();
          var href = link.getAttribute("href") || "";
          var id = href.slice(1) || link.getAttribute("data-toc-id");
          scrollToHeading(id, "smooth");
        });
      });

      if (window.location.hash) {
        requestAnimationFrame(function() {
          var id = window.location.hash.replace(/^#/, "");
          scrollToHeading(id, "auto");
        });
      }
    })();
  </script>
</Layout>
