                      <div>sub: <span class="text-[var(--color-fg)]">agt_k7x9m2</span></div>
                      <div>aud: <span class="text-[var(--color-fg)]">auth.bank.com</span></div>
                      <div>exp: <span class="text-[var(--color-fg)]">60 seconds</span></div>
                      <div>capabilities: <span class="text-[var(--color-fg)]">[check_balance]</span></div>
                    </div>
                  </div>
                </div>
                <div class="flex gap-3 items-start">
                  <span class="text-[var(--color-fg)] shrink-0 w-4 text-right">3</span>
                  <span>Agent sends request with JWT to server</span>
                </div>
                <div class="flex gap-3 items-start">
                  <span class="text-[var(--color-fg)] shrink-0 w-4 text-right">4</span>
                  <span>Server verifies signature + checks permissions</span>
