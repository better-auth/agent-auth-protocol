---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
---

<Layout title="Overview — Agent Auth Protocol">
  <Nav active="/overview" />

  <main class="flex-1">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-6 py-16 sm:py-20">

      <!-- Hero -->
      <div class="mb-24">
        <p class="text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-[0.2em] text-[var(--color-muted)] mb-4">Overview</p>
        <div class="flex flex-col lg:flex-row gap-10 lg:gap-16">
          <div class="lg:flex-1">
            <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-[2.75rem] font-semibold tracking-tight leading-[1.15] mb-6">
              How Agent Auth works
            </h1>
            <div class="overview-prose max-w-xl">
              <p class="text-lead">
                When you ask Claude, ChatGPT, or Cursor to do something — check your bank balance, create a PR, send a message — it needs to talk to external services. Today it does that using your OAuth token or a shared API key.
              </p>
              <p>
                The problem is the service can't tell <em>which</em> agent is calling. All agents look the same. You can't give one read-only access and another full access. You can't revoke one without revoking all of them.
              </p>
              <p>
                Agent Auth gives each agent task its own cryptographic identity, its own set of permissions, and its own lifecycle. The service sees a distinct principal for each agent and can manage them independently.
              </p>
            </div>
          </div>
          <div class="lg:w-[440px] xl:w-[480px] shrink-0">
            <div class="border border-[var(--color-border)] bg-[var(--color-surface)]">
              <div class="px-4 py-2.5 border-b border-[var(--color-border)] text-[10px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-[var(--color-muted)]">Today vs. Agent Auth</div>
              <div class="p-5 space-y-5">
                <div>
                  <div class="text-[10px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-red-400 mb-2">Without Agent Auth</div>
                  <div class="flex items-center gap-2 text-[12px] font-[family-name:var(--font-mono)] text-[var(--color-muted)]">
                    <div class="flex flex-col items-center gap-1">
                      <div class="w-8 h-8 border border-[var(--color-border)] flex items-center justify-center text-[9px]">A1</div>
                      <div class="w-8 h-8 border border-[var(--color-border)] flex items-center justify-center text-[9px]">A2</div>
                      <div class="w-8 h-8 border border-[var(--color-border)] flex items-center justify-center text-[9px]">A3</div>
                    </div>
                    <div class="flex flex-col items-center gap-0.5 mx-1">
                      <svg class="w-4 h-4 text-[var(--color-muted)] opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </div>
                    <div class="flex-1 border border-dashed border-red-400/30 p-2.5 text-center">
                      <div class="text-[10px] text-red-400 mb-1">Same token</div>
                      <div class="text-[9px] text-[var(--color-muted)]">user_oauth_token_xyz</div>
                    </div>
                    <div class="flex flex-col items-center gap-0.5 mx-1">
                      <svg class="w-4 h-4 text-[var(--color-muted)] opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </div>
                    <div class="w-14 h-14 border border-[var(--color-border)] flex items-center justify-center text-[9px] text-center leading-tight bg-[var(--color-bg)]">Bank<br/>API</div>
                  </div>
                </div>
                <div class="border-t border-[var(--color-border)] pt-5">
                  <div class="text-[10px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-green-500 mb-2">With Agent Auth</div>
                  <div class="flex items-center gap-2 text-[12px] font-[family-name:var(--font-mono)] text-[var(--color-muted)]">
                    <div class="flex flex-col items-center gap-1">
                      <div class="w-8 h-8 border border-green-500/30 flex items-center justify-center text-[9px]">A1</div>
                      <div class="w-8 h-8 border border-green-500/30 flex items-center justify-center text-[9px]">A2</div>
                      <div class="w-8 h-8 border border-green-500/30 flex items-center justify-center text-[9px]">A3</div>
                    </div>
                    <div class="flex flex-col items-center gap-0.5 mx-1">
                      <svg class="w-4 h-4 text-[var(--color-muted)] opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </div>
                    <div class="flex-1 flex flex-col gap-1">
                      <div class="border border-green-500/20 px-2 py-1 text-[9px] bg-green-500/5"><span class="text-green-500">agt_1</span> read:balance</div>
                      <div class="border border-green-500/20 px-2 py-1 text-[9px] bg-green-500/5"><span class="text-green-500">agt_2</span> read + write</div>
                      <div class="border border-green-500/20 px-2 py-1 text-[9px] bg-green-500/5"><span class="text-green-500">agt_3</span> read:txn</div>
                    </div>
                    <div class="flex flex-col items-center gap-0.5 mx-1">
                      <svg class="w-4 h-4 text-[var(--color-muted)] opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </div>
                    <div class="w-14 h-14 border border-[var(--color-border)] flex items-center justify-center text-[9px] text-center leading-tight bg-[var(--color-bg)]">Bank<br/>API</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- What is an Agent / Host / Server -->
      <div class="flex items-center gap-3 mb-8">
        <span class="text-[10px] font-[family-name:var(--font-mono)] tracking-[0.15em] uppercase text-[var(--color-muted)]">Key concepts</span>
        <div class="flex-1 border-t border-[var(--color-border)]"></div>
      </div>

      <div class="mb-24">
        <h2 class="text-xl sm:text-2xl font-semibold tracking-tight mb-4">Agents, hosts, and servers</h2>
        <p class="text-[15px] text-[var(--color-muted)] leading-[1.85] font-[family-name:var(--font-serif)] max-w-2xl mb-10">Three things you need to understand. The naming might feel unfamiliar at first, but the concepts are simple.</p>

        <div class="grid lg:grid-cols-3 gap-px bg-[var(--color-border)] border border-[var(--color-border)]">
          <div class="bg-[var(--color-bg)] p-6 sm:p-8">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="text-base font-semibold">Agent</h3>
              <span class="text-[10px] font-[family-name:var(--font-mono)] text-[var(--color-muted)] px-1.5 py-0.5 border border-[var(--color-border)]">identity</span>
            </div>
            <p class="text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)] mb-4">A single task or session, not the AI tool itself</p>
            <div class="overview-prose !text-[13px] !leading-relaxed mb-5">
              <p>An agent is <strong>not</strong> Claude Code or ChatGPT. It's a specific task running <em>inside</em> them.</p>
              <p>When you ask Cursor to "check my bank balance," that single task becomes an agent. It gets its own ID, its own cryptographic keys, and its own permissions. When the task ends, the agent can expire. A new task creates a new agent.</p>
              <p>Think of it like browser tabs. Chrome is not the tab — each tab has its own session, cookies, and can be closed independently.</p>
            </div>
            <div class="border border-[var(--color-border)] bg-[var(--color-surface)] p-3">
              <div class="text-[9px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-[var(--color-muted)] mb-2">Example</div>
              <div class="text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)] space-y-1">
                <div><span class="text-[var(--color-fg)]">Cursor</span> → agent: "check balance"</div>
                <div><span class="text-[var(--color-fg)]">Cursor</span> → agent: "transfer $250"</div>
                <div>Two tasks, two agents, two identities</div>
              </div>
            </div>
          </div>

          <div class="bg-[var(--color-bg)] p-6 sm:p-8">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="text-base font-semibold">Host</h3>
              <span class="text-[10px] font-[family-name:var(--font-mono)] text-[var(--color-muted)] px-1.5 py-0.5 border border-[var(--color-border)]">identity</span>
            </div>
            <p class="text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)] mb-4">The environment agents run inside</p>
            <div class="overview-prose !text-[13px] !leading-relaxed mb-5">
              <p>A host is the <strong>environment</strong> where agents are created and run. It could be Cursor on your MacBook, Claude Code on your laptop, a ChatGPT server in the cloud, or a CI pipeline.</p>
              <p>The host persists. Agents come and go, but the host stays. When you trust a host once ("yes, Cursor on my laptop can access my bank"), future agents from that host can be auto-approved.</p>
              <p>Think of it like your phone. You unlock your phone once (trust the host), then individual apps (agents) can make requests without re-authenticating every time.</p>
            </div>
            <div class="border border-[var(--color-border)] bg-[var(--color-surface)] p-3">
              <div class="text-[9px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-[var(--color-muted)] mb-2">Example hosts</div>
              <div class="text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)] space-y-1">
                <div>Cursor on your MacBook</div>
                <div>Claude Code on a remote server</div>
                <div>A CI/CD pipeline runner</div>
                <div>An MCP server on your machine</div>
              </div>
            </div>
          </div>

          <div class="bg-[var(--color-bg)] p-6 sm:p-8">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="text-base font-semibold">Server</h3>
              <span class="text-[10px] font-[family-name:var(--font-mono)] text-[var(--color-muted)] px-1.5 py-0.5 border border-[var(--color-border)]">participant</span>
            </div>
            <p class="text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)] mb-4">The service your agent connects to</p>
            <div class="overview-prose !text-[13px] !leading-relaxed mb-5">
              <p>The server is the <strong>service</strong> your agent needs to access — your bank, GitHub, Slack, a deployment platform, anything with an API.</p>
              <p>The server runs the Agent Auth protocol. It manages registrations, tracks which agents have which capabilities, and verifies every signed request.</p>
              <p>The server also defines <strong>capabilities</strong> — the specific actions agents can perform. "Check balance," "send message," "create PR" are all capabilities. The agent requests them, the user approves, and the server enforces.</p>
            </div>
            <div class="border border-[var(--color-border)] bg-[var(--color-surface)] p-3">
              <div class="text-[9px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-[var(--color-muted)] mb-2">Example servers</div>
              <div class="text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)] space-y-1">
                <div>Your bank's API</div>
                <div>GitHub / GitLab</div>
                <div>Slack, Linear, Notion</div>
                <div>Any service with Agent Auth</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Discovery -->
      <div class="flex items-center gap-3 mb-8">
        <span class="text-[10px] font-[family-name:var(--font-mono)] tracking-[0.15em] uppercase text-[var(--color-muted)]">Step 1</span>
        <div class="flex-1 border-t border-[var(--color-border)]"></div>
      </div>

      <div class="mb-24">
        <h2 class="text-xl sm:text-2xl font-semibold tracking-tight mb-4">Discovery — how agents find and connect to services</h2>
        <div class="overview-prose max-w-2xl mb-10">
          <p>Right now, connecting an agent to a service requires manual configuration. You need to find the right MCP server, add it to your config, provide API keys, and hope the agent knows how to use it. The agent has no way to look at a service and figure out how to connect on its own.</p>
          <p>Agent Auth changes this by standardizing discovery. Every Agent Auth server publishes a <code>/.well-known/agent-configuration</code> endpoint — similar to how OAuth servers publish <code>/.well-known/openid-configuration</code>. That endpoint describes everything the agent needs: what modes the server supports, what endpoints to call, and what capabilities are available.</p>
          <p>This means two concrete things:</p>
        </div>

        <div class="grid lg:grid-cols-2 gap-px bg-[var(--color-border)] border border-[var(--color-border)] mb-10">
          <div class="bg-[var(--color-bg)] p-5 sm:p-6">
            <h3 class="text-[13px] font-semibold mb-2">Given a URL, the agent can figure out the rest</h3>
            <p class="text-[13px] text-[var(--color-muted)] leading-relaxed mb-3">You tell the agent "connect to bank.com." The agent fetches <code class="text-[11px] bg-[var(--color-surface)] px-1 border border-[var(--color-border)]">bank.com/.well-known/agent-configuration</code>, reads the server's config, lists available capabilities, and knows exactly how to register and authenticate. No manual setup, no config files, no API keys to copy-paste.</p>
            <p class="text-[12px] text-[var(--color-muted)] leading-relaxed">The well-known endpoint returns the issuer URL, supported algorithms, registration endpoints, capability list endpoints, and approval methods. The agent has everything it needs to proceed to registration.</p>
          </div>
          <div class="bg-[var(--color-bg)] p-5 sm:p-6">
            <h3 class="text-[13px] font-semibold mb-2">The agent can search for services it needs</h3>
            <p class="text-[13px] text-[var(--color-muted)] leading-relaxed mb-3">You don't even need to know the URL. If you ask an agent to "check my bank balance," it can query an Agent Auth <strong>registry</strong> — a searchable index of servers that support the protocol. The registry returns matching providers with their connection URLs, and the agent (or the user) picks one.</p>
            <p class="text-[12px] text-[var(--color-muted)] leading-relaxed">This works for both delegated agents (where the user picks) and autonomous agents (where the agent picks based on its task requirements). The registry is a standard part of the protocol (§7.10).</p>
          </div>
        </div>

        <div class="grid lg:grid-cols-2 gap-6">
          <!-- Direct URL discovery -->
          <div class="border border-[var(--color-border)] overflow-hidden">
            <div class="px-4 py-2.5 border-b border-[var(--color-border)] bg-[var(--color-surface)]">
              <div class="text-[10px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-[var(--color-muted)]">Direct URL Discovery</div>
            </div>
            <div class="p-5 sm:p-6 min-h-[320px]">
              <div class="text-[11px] text-[var(--color-muted)] font-[family-name:var(--font-mono)] mb-4 flex items-center gap-2">
                <span class="text-[var(--color-fg)]">User says:</span> "Connect me to bank.com"
              </div>
              <div class="space-y-2">
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-fg)]">›</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5]">Agent receives URL: bank.com</div>
                  </div>
                </div>
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)]">›</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5]">Fetches well-known configuration</div>
                    <div class="mt-0.5 font-[family-name:var(--font-mono)] text-[10px] text-[var(--color-muted)] overflow-hidden text-ellipsis whitespace-nowrap">GET bank.com/.well-known/agent-configuration</div>
                  </div>
                </div>
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-green-500">✓</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5] font-medium text-[var(--color-fg)]">Server found: "Bank Services"</div>
                  </div>
                </div>
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)]">›</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5]">Reads server configuration</div>
                    <div class="mt-1 whitespace-pre-wrap border border-[var(--color-border)] bg-[var(--color-surface)] px-2 py-1.5 font-[family-name:var(--font-mono)] text-[10px] leading-[1.6] text-[var(--color-muted)]">issuer: https://auth.bank.com
modes: [delegated, autonomous]
algorithms: [Ed25519]</div>
                  </div>
                </div>
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)]">›</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5]">Fetches available capabilities</div>
                    <div class="mt-0.5 font-[family-name:var(--font-mono)] text-[10px] text-[var(--color-muted)] overflow-hidden text-ellipsis whitespace-nowrap">GET /capability/list</div>
                  </div>
                </div>
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-green-500">✓</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5] font-medium text-[var(--color-fg)]">Capabilities discovered</div>
                    <div class="mt-0.5 font-[family-name:var(--font-mono)] text-[10px] text-[var(--color-muted)] overflow-hidden text-ellipsis whitespace-nowrap">check_balance, transfer_domestic, transfer_international, list_accounts</div>
                  </div>
                </div>
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-fg)]">→</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5] font-medium text-[var(--color-fg)]">Ready to register an agent and connect</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Registry discovery -->
          <div class="border border-[var(--color-border)] overflow-hidden">
            <div class="px-4 py-2.5 border-b border-[var(--color-border)] bg-[var(--color-surface)]">
              <div class="text-[10px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-[var(--color-muted)]">Registry Search Discovery</div>
            </div>
            <div class="p-5 sm:p-6 min-h-[320px]">
              <div class="text-[11px] text-[var(--color-muted)] font-[family-name:var(--font-mono)] mb-4 flex items-center gap-2">
                <span class="text-[var(--color-fg)]">User says:</span> "Find me a service to check my balance"
              </div>
              <div class="space-y-2">
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-fg)]">›</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5]">Agent searches: "check bank balance"</div>
                  </div>
                </div>
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)]">›</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5]">Queries the Agent Auth registry</div>
                    <div class="mt-0.5 font-[family-name:var(--font-mono)] text-[10px] text-[var(--color-muted)] overflow-hidden text-ellipsis whitespace-nowrap">GET registry.agentauth.dev/search?q=bank+balance</div>
                  </div>
                </div>
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-green-500">✓</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5] font-medium text-[var(--color-fg)]">Found 3 matching providers</div>
                  </div>
                </div>
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)]">›</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5]">Registry results</div>
                    <div class="mt-1 whitespace-pre-wrap border border-[var(--color-border)] bg-[var(--color-surface)] px-2 py-1.5 font-[family-name:var(--font-mono)] text-[10px] leading-[1.6] text-[var(--color-muted)]">1. Bank of America  → auth.bofa.com
2. Chase Bank       → auth.chase.com
3. Acme Bank        → auth.acme.com</div>
                  </div>
                </div>
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-fg)]">›</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5]">User picks "Acme Bank" or the agent picks autonomously</div>
                  </div>
                </div>
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)]">›</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5]">Fetches Acme Bank configuration</div>
                    <div class="mt-0.5 font-[family-name:var(--font-mono)] text-[10px] text-[var(--color-muted)] overflow-hidden text-ellipsis whitespace-nowrap">GET auth.acme.com/.well-known/agent-configuration</div>
                  </div>
                </div>
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-green-500">✓</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5] font-medium text-[var(--color-fg)]">Connected: capabilities include `check_balance` and `transfer`</div>
                  </div>
                </div>
                <div class="flex gap-[10px] items-start py-[5px]">
                  <span class="shrink-0 w-4 mt-px text-center text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-fg)]">→</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-[12px] leading-[1.5] font-medium text-[var(--color-fg)]">Ready to register an agent</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Registration -->
      <div class="flex items-center gap-3 mb-8">
