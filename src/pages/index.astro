---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";

export const prerender = true;
---

<Layout title="Agent Auth Protocol — AI Agent Identity & Authorization" darkMode={true}>
  <Nav active="/" showThemeToggle={true} />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-[var(--color-bg)]">

    <div
      class="absolute inset-0 hidden pointer-events-none select-none dark:block"
      aria-hidden="true"
      style="background:
        radial-gradient(ellipse 80% 65% at 50% 25%, transparent 0%, rgba(0, 0, 0, 0.18) 58%, rgba(0, 0, 0, 0.5) 100%),
        linear-gradient(to bottom, rgba(0, 0, 0, 0.18) 0%, rgba(0, 0, 0, 0.36) 100%);"
    ></div>

    <div
      class="absolute inset-0 hidden pointer-events-none select-none dark:block"
      aria-hidden="true"
      style="background: linear-gradient(to bottom, transparent 0%, var(--color-fg) 50%, transparent 100%); background-size: 100% 3px; background-repeat: repeat; opacity: 0.015;"
    ></div>

    <div
      class="absolute -top-24 -right-20 hidden h-[26rem] w-[26rem] rounded-full pointer-events-none select-none dark:block"
      aria-hidden="true"
      style="background: radial-gradient(circle, var(--color-fg) 0%, transparent 70%); opacity: 0.035; filter: blur(70px);"
    ></div>
    <div
      class="absolute -bottom-32 -left-24 hidden h-[30rem] w-[30rem] rounded-full pointer-events-none select-none dark:block"
      aria-hidden="true"
      style="background: radial-gradient(circle, var(--color-fg) 0%, transparent 70%); opacity: 0.03; filter: blur(90px);"
    ></div>

    <div class="absolute inset-0 pointer-events-none select-none overflow-hidden" aria-hidden="true">
      <span class="absolute bottom-[1.15rem] right-9 text-[8px] font-[family-name:var(--font-mono)] uppercase tracking-[0.2em] text-[color:color-mix(in_oklch,var(--color-fg)_12%,transparent)] dark:text-[color:color-mix(in_oklch,var(--color-fg)_22%,transparent)]">
        draft.v1
      </span>
    </div>

    <div class="relative z-10 mx-auto max-w-[1400px] px-5 sm:px-6 py-12 sm:py-14 lg:py-16">
      <div class="mx-auto flex max-w-5xl flex-col items-center text-center">
        <h1 class="max-w-4xl text-balance text-4xl font-semibold tracking-[-0.04em] sm:text-5xl md:text-6xl lg:text-[4.15rem] lg:leading-[0.98]">
          Agent Auth <span class="font-light text-[color:color-mix(in_oklch,var(--color-fg)_70%,transparent)]">Protocol</span>
        </h1>

        <p class="mt-4 max-w-2xl text-pretty text-base leading-relaxed text-[color:color-mix(in_oklch,var(--color-fg)_62%,transparent)] sm:text-lg">
          A protocol for agent authentication, authorization, and service discovery. It defines how agents establish identity, receive scoped capabilities, and operate with clear attribution.
        </p>

        <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
          <a href="/specification" class="inline-flex items-center gap-2 border border-[var(--color-fg)] bg-[var(--color-fg)] px-4 py-2 text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-[var(--color-bg)] transition-opacity hover:opacity-90">
            Read the spec
          </a>
          <a href="/overview" class="inline-flex items-center gap-2 border border-[color:color-mix(in_oklch,var(--color-fg)_14%,transparent)] bg-[color:color-mix(in_oklch,var(--color-fg)_4%,transparent)] px-4 py-2 text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-[color:color-mix(in_oklch,var(--color-fg)_68%,transparent)] transition-colors hover:border-[color:color-mix(in_oklch,var(--color-fg)_28%,transparent)] hover:text-[var(--color-fg)]">
            Protocol overview
          </a>
        </div>
      </div>
    </div>

    <div
      class="absolute inset-x-0 bottom-0 h-24 pointer-events-none select-none"
      aria-hidden="true"
      style="background: linear-gradient(to bottom, transparent 0%, var(--color-bg) 100%);"
    ></div>
  </section>

  <!-- The problem -->
  <section class="relative">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-6 pb-16">
      <div class="flex items-center gap-3 mb-6">
        <span
          class="inline-flex items-center border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-1 text-[10px] sm:text-[11px] font-[family-name:var(--font-mono)] tracking-[0.14em] uppercase text-[var(--color-fg)]"
          style="background-image: radial-gradient(color-mix(in srgb, var(--color-body) 18%, transparent) 0.65px, transparent 0.65px); background-size: 8px 8px;"
        >Delegated agents</span>
        <div class="h-px flex-1 bg-gradient-to-r from-[var(--color-border)] to-transparent"></div>
      </div>
      <p class="text-[15px] text-[var(--color-body)] leading-[1.8] max-w-2xl mb-8">Agent integrations today reuse a user's API keys, OAuth tokens, or a shared client credential. That collapses the agent into the user's identity — there's no per-agent visibility, scoping, approval, or revocation.</p>

      <div class="border border-[var(--color-border)] bg-[var(--color-bg)]">
        <div class="grid md:grid-cols-2">
          <div class="px-6 sm:px-8 py-7 border-b md:border-b-0 md:border-r border-[var(--color-border)]">
            <div class="text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-red-500 mb-4">Today</div>
            <div class="flex flex-col sm:flex-row items-center gap-3 text-[11px] sm:text-[12px] font-[family-name:var(--font-mono)] text-[var(--color-body)]">
              <div class="flex flex-col items-center gap-1.5">
                <div class="w-11 h-11 border border-[var(--color-border)] flex items-center justify-center text-[10px]">A1</div>
                <div class="w-11 h-11 border border-[var(--color-border)] flex items-center justify-center text-[10px]">A2</div>
                <div class="w-11 h-11 border border-[var(--color-border)] flex items-center justify-center text-[10px]">A3</div>
              </div>
              <svg class="w-5 h-5 rotate-90 sm:rotate-0 opacity-60 shrink-0 text-[var(--color-body)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              <div class="w-full flex-1 border border-dashed border-red-400/30 px-3 py-2.5 text-center">
                <div class="text-[11px] text-red-500">same token</div>
                <div class="text-[10px] mt-0.5 text-[var(--color-body)]">user_oauth_xyz</div>
              </div>
              <svg class="w-5 h-5 rotate-90 sm:rotate-0 opacity-60 shrink-0 text-[var(--color-body)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              <div class="shrink-0 w-16 h-16 border border-[var(--color-border)] flex items-center justify-center text-[10px] text-center leading-tight bg-[var(--color-surface)]">Bank<br/>API</div>
            </div>
            <p class="text-[12px] text-[var(--color-body)] leading-relaxed mt-4">All agents share one token. The server sees the user, not the agent.</p>
          </div>
          <div class="px-6 sm:px-8 py-7">
            <div class="text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-green-600 mb-4">With Agent Auth</div>
            <div class="flex flex-col sm:flex-row items-center gap-3 text-[11px] sm:text-[12px] font-[family-name:var(--font-mono)] text-[var(--color-body)]">
              <div class="flex flex-col items-center gap-1.5">
                <div class="w-11 h-11 border border-green-500/30 flex items-center justify-center text-[10px] text-green-600">A1</div>
                <div class="w-11 h-11 border border-green-500/30 flex items-center justify-center text-[10px] text-green-600">A2</div>
                <div class="w-11 h-11 border border-green-500/30 flex items-center justify-center text-[10px] text-green-600">A3</div>
              </div>
              <svg class="w-5 h-5 rotate-90 sm:rotate-0 opacity-60 shrink-0 text-[var(--color-body)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              <div class="w-full flex-1 flex flex-col gap-1.5">
                <div class="border border-green-500/20 px-3 py-1.5 text-[10px] bg-green-500/5 flex justify-between"><span><span class="text-green-600">agt_1</span> check_balance</span><span class="text-green-600">✓</span></div>
                <div class="border border-green-500/20 px-3 py-1.5 text-[10px] bg-green-500/5 flex justify-between"><span><span class="text-green-600">agt_2</span> transfer_funds</span><span class="text-green-600">✓</span></div>
                <div class="border border-green-500/20 px-3 py-1.5 text-[10px] bg-green-500/5 flex justify-between"><span><span class="text-green-600">agt_3</span> list_transactions</span><span class="text-green-600">✓</span></div>
              </div>
              <svg class="w-5 h-5 rotate-90 sm:rotate-0 opacity-60 shrink-0 text-[var(--color-body)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              <div class="shrink-0 w-16 h-16 border border-[var(--color-border)] flex items-center justify-center text-[10px] text-center leading-tight bg-[var(--color-surface)]">Bank<br/>API</div>
            </div>
            <p class="text-[12px] text-[var(--color-body)] leading-relaxed mt-4">Each agent has its own identity. Every request traces back to a specific agent.</p>
          </div>
        </div>

        <!-- Bottom bar -->
        <div class="border-t border-[var(--color-border)] px-6 sm:px-8 py-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-[var(--color-surface)]">
          <p class="text-[14px] text-[var(--color-body)] leading-relaxed max-w-xl">Agent Auth treats each agent as a first-class principal with its own identity, granted capabilities, and lifecycle.</p>
          <a href="/overview" class="text-[12px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-[var(--color-body)] hover:text-[var(--color-fg)] transition-colors whitespace-nowrap shrink-0">
            Read the overview →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Autonomous agents -->
  <section class="relative">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-6 pb-16">
      <div class="flex items-center gap-3 mb-6">
        <span
          class="inline-flex items-center border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-1 text-[10px] sm:text-[11px] font-[family-name:var(--font-mono)] tracking-[0.14em] uppercase text-[var(--color-fg)]"
          style="background-image: radial-gradient(color-mix(in srgb, var(--color-body) 18%, transparent) 0.65px, transparent 0.65px); background-size: 8px 8px;"
        >Autonomous agents</span>
        <div class="h-px flex-1 bg-gradient-to-r from-[var(--color-border)] to-transparent"></div>
      </div>
      <p class="text-[15px] text-[var(--color-body)] leading-[1.8] max-w-2xl mb-8">Background workers, scheduled jobs, and service-to-service agents need to authenticate without a user session. Today they usually inherit a human user's credentials, so user and agent collapse into one principal and the server cannot tell who acted. Browser signup and CAPTCHA loops are symptoms of this same identity gap.</p>

      <div class="border border-[var(--color-border)] bg-[var(--color-bg)]">
        <div class="grid lg:grid-cols-2">
          <!-- Today -->
          <div class="p-6 sm:p-8 border-b lg:border-b-0 lg:border-r border-[var(--color-border)]">
            <div class="text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-red-500 mb-4">Today</div>
            <div class="border border-[var(--color-border)] bg-[var(--color-surface)] p-3 sm:p-4 mb-3">
              <div class="flex flex-col sm:flex-row items-center gap-3 text-[11px] sm:text-[12px] font-[family-name:var(--font-mono)] text-[var(--color-body)]">
                <div class="flex flex-col items-center gap-1.5">
                  <div class="w-11 h-11 border border-[var(--color-border)] flex items-center justify-center text-[10px]">A1</div>
                  <div class="w-11 h-11 border border-[var(--color-border)] flex items-center justify-center text-[10px]">A2</div>
                  <div class="w-11 h-11 border border-[var(--color-border)] flex items-center justify-center text-[10px]">A3</div>
                </div>
                <svg class="w-5 h-5 rotate-90 sm:rotate-0 opacity-60 shrink-0 text-[var(--color-body)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                <div class="w-full flex-1 border border-dashed border-red-400/30 px-3 py-2.5 text-center">
                  <div class="text-[11px] text-red-500">impersonation window</div>
                  <div class="text-[10px] mt-0.5 text-[var(--color-body)]">shared user credential C</div>
                </div>
                <svg class="w-5 h-5 rotate-90 sm:rotate-0 opacity-60 shrink-0 text-[var(--color-body)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                <div class="shrink-0 w-16 h-16 border border-[var(--color-border)] flex items-center justify-center text-[10px] text-center leading-tight bg-[var(--color-bg)]">Server<br/>/ API</div>
              </div>
            </div>
            <p class="text-[12px] text-[var(--color-body)] leading-relaxed">Autonomous agents are routed through the same impersonation path and shared user credential. The server sees one principal and cannot tell which agent acted.</p>
          </div>

          <!-- With Agent Auth -->
          <div class="p-6 sm:p-8">
            <div class="text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-green-600 mb-4">With Agent Auth</div>
            <div class="border border-[var(--color-border)] bg-[var(--color-surface)] p-3 sm:p-4 mb-3">
              <div class="flex flex-col sm:flex-row items-center gap-3 text-[11px] sm:text-[12px] font-[family-name:var(--font-mono)] text-[var(--color-body)]">
                <div class="flex flex-col items-center gap-1.5">
                  <div class="w-11 h-11 border border-green-500/30 flex items-center justify-center text-[10px] text-green-600">A1</div>
                  <div class="w-11 h-11 border border-green-500/30 flex items-center justify-center text-[10px] text-green-600">A2</div>
                  <div class="w-11 h-11 border border-green-500/30 flex items-center justify-center text-[10px] text-green-600">A3</div>
                </div>
                <svg class="w-5 h-5 rotate-90 sm:rotate-0 opacity-60 shrink-0 text-[var(--color-body)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                <div class="w-full flex-1 flex flex-col gap-1.5">
                  <div class="border border-green-500/20 px-3 py-1.5 text-[10px] bg-green-500/5 flex justify-between"><span><span class="text-green-600">auto_1</span> own auth context</span><span class="text-green-600">✓</span></div>
                  <div class="border border-green-500/20 px-3 py-1.5 text-[10px] bg-green-500/5 flex justify-between"><span><span class="text-green-600">auto_2</span> own auth context</span><span class="text-green-600">✓</span></div>
                  <div class="border border-green-500/20 px-3 py-1.5 text-[10px] bg-green-500/5 flex justify-between"><span><span class="text-green-600">auto_3</span> own auth context</span><span class="text-green-600">✓</span></div>
                </div>
                <svg class="w-5 h-5 rotate-90 sm:rotate-0 opacity-60 shrink-0 text-[var(--color-body)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                <div class="shrink-0 w-16 h-16 border border-[var(--color-border)] flex items-center justify-center text-[10px] text-center leading-tight bg-[var(--color-bg)]">Server<br/>/ API</div>
              </div>
            </div>
            <p class="text-[12px] text-[var(--color-body)] leading-relaxed">Each autonomous agent gets its own identity and credential path, so the server can attribute actions to the exact agent instance.</p>
          </div>
        </div>
      </div>
      <!-- Discovery (part of autonomous agents) -->
      <p class="text-[15px] text-[var(--color-body)] leading-[1.8] max-w-2xl mb-8 mt-10">This extends to discovery. Before an autonomous agent can authenticate, it needs to find services without a human pointing it to the right URL. Agent Auth standardizes this — agents resolve a well-known endpoint or query a registry.</p>

      <div class="border border-[var(--color-border)] bg-[var(--color-bg)]">
        <div class="grid lg:grid-cols-2">
          <div class="p-6 sm:p-8 border-b lg:border-b-0 lg:border-r border-[var(--color-border)]">
            <div class="text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-red-500 mb-4">Today</div>
            <div class="grid gap-3 mb-3 md:grid-cols-[minmax(0,1fr)_140px] text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-body)]">
              <div class="space-y-1.5">
                <div class="border border-dashed border-red-400/30 px-3 py-2">1. Find the right MCP server</div>
                <div class="border border-dashed border-red-400/30 px-3 py-2">2. Add it to your config file</div>
                <div class="border border-dashed border-red-400/30 px-3 py-2">3. Create API key, paste it in</div>
                <div class="border border-dashed border-red-400/30 px-3 py-2">4. Hope the agent knows how to use it</div>
              </div>
              <div class="border border-dashed border-[var(--color-border)] bg-[var(--color-surface)] p-3">
                <div class="text-[10px] uppercase tracking-[0.12em] text-red-500 mb-2">Manual setup</div>
                <div class="space-y-1.5 text-[10px] opacity-80">
                  <div>servers.json</div>
                  <div>API_KEY=sk_live_...</div>
                  <div>custom docs</div>
                  <div>trial and error</div>
                </div>
              </div>
            </div>
            <p class="text-[12px] text-[var(--color-body)] leading-relaxed">Every new service means manual setup. No standard way for agents to find and connect to services.</p>
          </div>
          <div class="p-6 sm:p-8">
            <div class="text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-green-600 mb-4">With Agent Auth</div>
            <div class="border border-[var(--color-border)] bg-[var(--color-surface)] p-4 sm:p-5 mb-3">
              <div class="grid gap-4 lg:grid-cols-2 text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-body)]">
                <div>
                  <div class="text-[10px] uppercase tracking-[0.12em] opacity-75 mb-2">By URL</div>
                  <div class="space-y-2">
                    <div class="border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-2">bank.com</div>
                    <div class="pl-3 border-l border-dashed border-green-500/30 text-[10px] opacity-75">resolve <code>/.well-known/agent-configuration</code></div>
                    <div class="border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-2">capabilities, auth methods, approval URL</div>
                    <div class="text-green-600 text-[10px]">auto-configured connection</div>
                  </div>
                </div>
                <div>
                  <div class="text-[10px] uppercase tracking-[0.12em] opacity-75 mb-2">By intent</div>
                  <div class="space-y-2">
                    <div class="border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-2">"check my bank balance"</div>
                    <div class="pl-3 border-l border-dashed border-green-500/30 text-[10px] opacity-75">query registry for matching providers</div>
                    <div class="grid gap-1.5">
                      <div class="border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-2 flex items-center justify-between"><span>auth.bank.com</span><span class="text-green-600">best match</span></div>
                      <div class="border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-2 opacity-70">finance.example</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <p class="text-[12px] text-[var(--color-body)] leading-relaxed">The agent resolves a well-known configuration endpoint from the URL, or queries a registry to find providers matching the task.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Get started -->
  <section class="relative">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-6 pb-16">
      <h2 class="text-lg sm:text-xl font-semibold tracking-tight mb-4">Get started</h2>
      <ul class="space-y-2 text-[15px] text-[var(--color-body)] leading-[1.8]">
        <li><a href="/specification" class="text-[var(--color-fg)] underline underline-offset-3 decoration-[var(--color-border)] hover:decoration-[var(--color-fg)] transition-colors">Read the specification</a> — identity model, registration, capabilities, discovery, and JWT verification.</li>
        <li><a href="/implementations" class="text-[var(--color-fg)] underline underline-offset-3 decoration-[var(--color-border)] hover:decoration-[var(--color-fg)] transition-colors">Better Auth plugin</a> — add Agent Auth to your app with a single plugin.</li>
        <li><a href="/registry" class="text-[var(--color-fg)] underline underline-offset-3 decoration-[var(--color-border)] hover:decoration-[var(--color-fg)] transition-colors">Submit your server</a> — register so agents can discover it through the registry.</li>
      </ul>
    </div>
  </section>

  <!-- Ask trigger -->
  <div class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 z-40 flex flex-col items-end" id="ask-trigger-wrap" style="translate: 0 120%; opacity: 0; transition: translate .5s cubic-bezier(.32,.72,0,1), opacity .4s ease;">
    <button
      id="ask-trigger"
      aria-label="Learn about the protocol"
      class="flex items-center justify-center cursor-pointer group w-11 h-11 border border-[color-mix(in_oklch,var(--color-fg)_10%,transparent)] backdrop-blur-md bg-[var(--color-bg)]/92 rounded-lg"
    >
      <svg class="w-4 h-4 text-[var(--color-muted)] group-hover:text-[var(--color-fg)] transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="4" y="4" width="16" height="16" rx="4" class="ask-agent-body"/>
        <circle cx="9.5" cy="12" r="1.5" fill="currentColor" stroke="none" class="ask-agent-eye"/>
        <circle cx="14.5" cy="12" r="1.5" fill="currentColor" stroke="none" class="ask-agent-eye"/>
        <line x1="12" y1="1" x2="12" y2="4" class="ask-agent-antenna"/>
        <circle cx="12" cy="1" r="1" fill="currentColor" stroke="none" class="ask-agent-dot"/>
      </svg>
    </button>
  </div>

  <!-- Ask sheet (fullscreen overlay) -->
  <div id="ask-sheet" class="fixed inset-0 z-50">
    <div id="ask-backdrop" class="absolute inset-0 bg-[var(--color-bg)]"></div>
    <div id="ask-panel" class="absolute inset-0 flex flex-col">
      <!-- Sheet header -->
      <nav class="shrink-0 relative z-10 bg-[var(--color-bg)]">
        <div class="mx-auto flex items-center h-11 px-5 sm:px-6 max-w-[1400px]">
          <div class="flex items-center gap-2.5">
            <span class="text-sm font-normal tracking-[0.08em] uppercase font-[family-name:var(--font-pixel)]">AGENT-AUTH.</span>
          </div>
          <div class="ml-auto">
            <button id="ask-close" class="inline-flex items-center gap-1.5 text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-[var(--color-muted)] hover:text-[var(--color-fg)] transition-colors cursor-pointer">
              Close
              <kbd class="text-[9px] px-1 py-0.5 border border-[var(--color-border)] text-[var(--color-muted)] leading-none">ESC</kbd>
            </button>
          </div>
        </div>
        <div class="h-px" style="background: linear-gradient(to right, transparent, var(--color-border) 15%, var(--color-border) 85%, transparent);"></div>
      </nav>

      <!-- Sheet body -->
      <div id="ask-response-area" class="flex-1 overflow-y-auto min-h-0">
        <div class="mx-auto max-w-[820px] w-full px-5 sm:px-8 py-8 sm:py-10">
          <div id="ask-welcome">
            <div class="mb-10">
              <p class="text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-[0.2em] text-[var(--color-muted)] mb-4">Overview</p>
              <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight leading-[1.2] mb-5">What is Agent Auth Protocol?</h1>
              <div class="ask-prose">
                <p>Agent Auth is an open protocol that gives AI agents their own identity. Instead of borrowing a user's OAuth token or sharing a single API key, each agent gets its own cryptographic keypair, its own granted capabilities, and its own lifecycle.</p>
                <p>The core flow is simple: a <strong>host</strong> (like Cursor, an MCP server, or a CLI tool) registers an <strong>agent</strong> with a server. The agent authenticates using Ed25519-signed JWTs. The user approves capabilities through a device authorization flow — similar to logging into a streaming app on your TV.</p>
                <p>This means servers can see exactly which agent made a request, scope what each agent can do, and revoke one agent without affecting others. It works for both <strong>delegated</strong> agents (acting on behalf of a user) and <strong>autonomous</strong> agents (operating independently).</p>
              </div>
            </div>

            <div class="border-t border-[var(--color-border)] pt-8">
              <p class="text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-[0.2em] text-[var(--color-muted)] mb-4">Dive deeper</p>
              <div class="grid sm:grid-cols-2 gap-2">
                <button class="ask-chip text-left px-4 py-3 text-[13px] text-[var(--color-fg)] border border-[var(--color-border)] hover:bg-[var(--color-surface)] transition-colors cursor-pointer">How does agent registration work?</button>
                <button class="ask-chip text-left px-4 py-3 text-[13px] text-[var(--color-fg)] border border-[var(--color-border)] hover:bg-[var(--color-surface)] transition-colors cursor-pointer">Explain the device authorization flow</button>
                <button class="ask-chip text-left px-4 py-3 text-[13px] text-[var(--color-fg)] border border-[var(--color-border)] hover:bg-[var(--color-surface)] transition-colors cursor-pointer">Delegated vs autonomous agents</button>
                <button class="ask-chip text-left px-4 py-3 text-[13px] text-[var(--color-fg)] border border-[var(--color-border)] hover:bg-[var(--color-surface)] transition-colors cursor-pointer">What are capabilities?</button>
                <button class="ask-chip text-left px-4 py-3 text-[13px] text-[var(--color-fg)] border border-[var(--color-border)] hover:bg-[var(--color-surface)] transition-colors cursor-pointer sm:col-span-2">How do agents sign requests?</button>
              </div>
            </div>
          </div>
          <div id="ask-messages" class="hidden"></div>
        </div>
      </div>

      <!-- Sheet input -->
      <div class="shrink-0 relative z-10 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-[820px] w-full px-5 sm:px-8 py-4">
          <div class="flex items-center gap-3 px-4 py-3 border border-[color-mix(in_oklch,var(--color-fg)_8%,transparent)] focus-within:border-[color-mix(in_oklch,var(--color-fg)_15%,transparent)] bg-[var(--color-surface)] transition-colors">
            <input
              id="ask-sheet-input"
              type="text"
