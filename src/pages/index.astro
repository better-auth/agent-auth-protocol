      );
      box-shadow: 0 1px 0 color-mix(in oklch, var(--color-fg) 4%, transparent);
    }
    #ask-messages .ask-msg-ai:last-child { margin-bottom: 0; border-bottom: none; }

    @keyframes thinking-dot {
      0%, 80%, 100% { opacity: 0.2; }
