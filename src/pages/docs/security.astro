---
import DocsLayout from "@/layouts/DocsLayout.astro";

export const prerender = true;

const headings = [
	{ depth: 2, slug: "private-keys", text: "Private keys" },
	{ depth: 2, slug: "jwt-lifetime", text: "JWT lifetime" },
	{ depth: 2, slug: "replay-protection", text: "Replay protection" },
	{ depth: 2, slug: "proof-of-possession", text: "Proof of possession" },
	{ depth: 2, slug: "approval-security", text: "Approval security" },
	{ depth: 2, slug: "self-authorization", text: "Self-authorization attacks" },
	{ depth: 2, slug: "discovery-security", text: "Discovery security" },
	{ depth: 2, slug: "key-compromise", text: "Key compromise" },
	{ depth: 2, slug: "revocation", text: "Revocation cascade" },
	{ depth: 2, slug: "rate-limiting", text: "Rate limiting" },
	{ depth: 2, slug: "url-fetch-protection", text: "URL fetch protection" },
