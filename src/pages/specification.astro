---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { getSpecContent, type SpecTocEntry } from "@/lib/spec-content";

const { html, toc } = getSpecContent("spec.mdx");

const topLevel = toc.filter((e: SpecTocEntry) => e.level === 2);

function isSectionChild(parentText: string, childText: string): boolean {
  const parentNum = parentText.match(/^(\d+|[A-Z])\./)?.[1];
  if (!parentNum) return false;
  const childNum = childText.match(/^(\d+|[A-Z])\.\d/)?.[1];
  return parentNum === childNum;
}

function isSubChild(parentText: string, childText: string): boolean {
  const parentMatch = parentText.match(/^((\d+|[A-Z])\.\d+)/);
  if (!parentMatch) return false;
  const prefix = parentMatch[1];
  return childText.startsWith(prefix + ".");
}
---

<Layout title="Specification — Agent Auth Protocol" bodyClass="spec-page-body" darkMode>
  <div id="spec-nav" class="spec-nav-collapsible">
    <Nav active="/specification" />
  </div>
  <div class="spec-shell" id="spec-shell">
    <!-- Spec content (left) -->
    <div class="spec-reader-content" id="spec-scroll-container">
      <article class="spec-content-area">
        <div class="spec-version-bar">
          <span class="spec-version-tag">v1.0-draft</span>
        </div>
        <div class="spec-content" data-pagefind-body set:html={html} />
      </article>
      <Footer />
    </div>

    <!-- TOC (right) -->
    <aside class="spec-reader-toc">
      <nav aria-label="Table of Contents">
        <ul class="space-y-0">
          {topLevel.map((entry: SpecTocEntry) => {
            const children = toc.filter(
              (e: SpecTocEntry) => e.level === 3 && isSectionChild(entry.text, e.text)
            );
            return (
              <li>
                <a href={`#${entry.id}`} class="spec-toc-link" data-toc-id={entry.id}>
                  {entry.text}
                </a>
                {children.length > 0 && (
                  <ul class="spec-toc-children" data-parent-id={entry.id}>
                    {children.map((child: SpecTocEntry) => {
                      const grandchildren = toc.filter(
                        (e: SpecTocEntry) => e.level === 4 && isSubChild(child.text, e.text)
                      );
                      return (
                        <li>
                          <a href={`#${child.id}`} class="spec-toc-child" data-toc-id={child.id}>
                            {child.text}
                          </a>
                          {grandchildren.length > 0 && (
                            <ul class="spec-toc-grandchildren" data-parent-id={child.id}>
                              {grandchildren.map((gc: SpecTocEntry) => (
                                <li>
                                  <a href={`#${gc.id}`} class="spec-toc-grandchild" data-toc-id={gc.id}>
                                    {gc.text}
                                  </a>
                                </li>
                              ))}
                            </ul>
                          )}
                        </li>
                      );
                    })}
                  </ul>
                )}
              </li>
            );
          })}
        </ul>
      </nav>
    </aside>
  </div>

  <!-- Floating controls -->
  <div class="fixed bottom-5 right-5 z-50 flex items-center border border-[var(--color-border)] bg-[var(--color-bg)] rounded-full shadow-sm">
    <button
      id="spec-search-trigger"
      class="h-9 w-9 flex items-center justify-center text-[var(--color-muted)] hover:text-[var(--color-fg)] transition-colors cursor-pointer"
      aria-label="Search specification"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    </button>
    <div class="w-px h-4 bg-[var(--color-border)]"></div>
    <button
      id="theme-toggle"
      class="h-9 w-9 flex items-center justify-center text-[var(--color-muted)] hover:text-[var(--color-fg)] transition-colors cursor-pointer"
      aria-label="Toggle theme"
    >
      <svg class="h-4 w-4 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg class="h-4 w-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
  </div>

  <script is:inline>
    document.getElementById("theme-toggle")?.addEventListener("click", function() {
      var isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });

    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        var nav = document.getElementById("spec-nav");
        var shell = document.getElementById("spec-shell");
        if (nav) nav.classList.add("collapsed");
        if (shell) shell.classList.add("expanded");
      });
    });
  </script>

  <script is:inline>
    (function() {
      var container = document.getElementById("spec-scroll-container");
      if (!container) return;

      var headings = container.querySelectorAll("h2[id], h3[id], h4[id]");
      var tocLinks = document.querySelectorAll("[data-toc-id]");
      var internalLinks = document.querySelectorAll('.spec-content a[href^="#"], [data-toc-id][href^="#"]');
      var childGroups = document.querySelectorAll(".spec-toc-children");
      var grandchildGroups = document.querySelectorAll(".spec-toc-grandchildren");
      var tocMap = new Map();
      tocLinks.forEach(function(link) { tocMap.set(link.getAttribute("data-toc-id"), link); });

      function getAncestorSection(id, tag) {
        var el = document.getElementById(id);
        if (!el) return null;
        if (el.tagName.toLowerCase() === tag) return id;
        var prev = el;
        while ((prev = prev.previousElementSibling)) {
          if (prev.tagName.toLowerCase() === tag && prev.id) return prev.id;
        }
        return null;
      }

      function setActive(activeId) {
        tocLinks.forEach(function(link) { link.classList.remove("active"); });
        childGroups.forEach(function(g) { g.classList.remove("expanded"); });
        grandchildGroups.forEach(function(g) { g.classList.remove("expanded"); });

        var activeLink = tocMap.get(activeId);
        if (activeLink) activeLink.classList.add("active");

        var h2Id = getAncestorSection(activeId, "h2");
        if (h2Id) {
          var h2Link = tocMap.get(h2Id);
          if (h2Link && activeId !== h2Id) h2Link.classList.add("active");
          var childGroup = document.querySelector('.spec-toc-children[data-parent-id="' + h2Id + '"]');
          if (childGroup) childGroup.classList.add("expanded");
        }

        var h3Id = getAncestorSection(activeId, "h3");
        if (h3Id) {
          var h3Link = tocMap.get(h3Id);
          if (h3Link && activeId !== h3Id) h3Link.classList.add("active");
          var gcGroup = document.querySelector('.spec-toc-grandchildren[data-parent-id="' + h3Id + '"]');
          if (gcGroup) gcGroup.classList.add("expanded");
        }

        if (window.location.hash !== "#" + activeId) {
          window.history.replaceState(null, "", "#" + activeId);
        }
      }

      function scrollToHeading(id, behavior, pushHash) {
        if (!id) return;

        var el = document.getElementById(id);
        if (!el) return;

        var containerRect = container.getBoundingClientRect();
        var elRect = el.getBoundingClientRect();
        var offset = elRect.top - containerRect.top + container.scrollTop - 24;

        container.scrollTo({ top: offset, behavior: behavior || "smooth" });
        setActive(id);

        if (pushHash) {
          window.history.pushState(null, "", "#" + id);
        }
      }

      var observer = new IntersectionObserver(
        function(entries) {
          var visible = entries.filter(function(e) { return e.isIntersecting; });
          if (visible.length > 0) {
            visible.sort(function(a, b) { return a.boundingClientRect.top - b.boundingClientRect.top; });
            setActive(visible[0].target.id);
          }
        },
        { root: container, rootMargin: "-20px 0px -65% 0px", threshold: 0 }
      );

      headings.forEach(function(h) { observer.observe(h); });

      internalLinks.forEach(function(link) {
        link.addEventListener("click", function(e) {
          e.preventDefault();
          var href = link.getAttribute("href") || "";
          var id = href.slice(1) || link.getAttribute("data-toc-id");
          scrollToHeading(id, "smooth", true);
        });
      });

      function syncFromHash(behavior) {
        var id = window.location.hash.replace(/^#/, "");
        if (!id) return;
        scrollToHeading(id, behavior || "auto", false);
      }

      if (window.location.hash) {
        requestAnimationFrame(function() {
          syncFromHash("auto");
        });
      }

      window.addEventListener("hashchange", function() {
        syncFromHash("smooth");
      });
    })();
  </script>
</Layout>
