---
import Layout from "@/layouts/Layout.astro";
import { buildHashToSectionMap } from "@/lib/spec-content";

const hashMap = buildHashToSectionMap();
const hashMapJson = JSON.stringify(Object.fromEntries(hashMap));
---

<Layout title="Specification — Agent Auth Protocol">
  <meta http-equiv="refresh" content="0; url=/specification/introduction" />
  <script is:inline define:vars={{ hashMapJson }}>
    (function() {
      var hash = window.location.hash.replace(/^#/, "");
      if (hash) {
        var map = JSON.parse(hashMapJson);
        var section = map[hash];
        if (section) {
          window.location.replace("/specification/" + section + "#" + hash);
          return;
        }
      }
      window.location.replace("/specification/introduction");
    })();
  </script>
</Layout>
