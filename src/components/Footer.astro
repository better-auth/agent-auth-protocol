---
interface Props {
  showThemeToggle?: boolean;
}

const { showThemeToggle = false } = Astro.props;
---

<footer class="mt-auto relative">
  <div class="border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-4">
        <span class="text-[11px] text-[var(--color-muted)] font-[family-name:var(--font-mono)]">© {new Date().getFullYear()} Better Auth Inc.</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="https://github.com/better-auth/agent-auth-protocol" target="_blank" rel="noopener noreferrer" class="text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)] hover:text-[var(--color-fg)] transition-colors">GitHub</a>
        <a href="/specification" class="text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)] hover:text-[var(--color-fg)] transition-colors">Specification</a>
        <a href="/code" class="text-[11px] font-[family-name:var(--font-mono)] text-[var(--color-muted)] hover:text-[var(--color-fg)] transition-colors">Code</a>
        {showThemeToggle && (
          <button
            id="footer-theme-toggle"
            class="inline-flex items-center justify-center h-7 w-7 text-[var(--color-muted)] hover:text-[var(--color-fg)] transition-colors cursor-pointer"
            aria-label="Toggle theme"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              class="h-5 w-5 block dark:hidden"
              aria-hidden="true"
            >
              <g
                fill="none"
                stroke="#888888"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
              >
                <path
                  stroke-dasharray="2"
                  stroke-dashoffset="0"
                  d="M12 21v1M21 12h1M12 3v-1M3 12h-1"
                />
                <path
                  stroke-dasharray="2"
                  stroke-dashoffset="0"
                  d="M18.5 18.5l0.5 0.5M18.5 5.5l0.5 -0.5M5.5 5.5l-0.5 -0.5M5.5 18.5l-0.5 0.5"
                />
                <animateTransform
                  attributeName="transform"
                  dur="30s"
                  repeatCount="indefinite"
                  type="rotate"
                  values="0 12 12;360 12 12"
                />
              </g>
              <circle cx="12" cy="12" r="6" fill="#424242" />
            </svg>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 32 32"
              class="h-5 w-5 hidden dark:block"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M16 2.66667V29.3333C19.5362 29.3333 22.9276 27.9286 25.4281 25.4281C27.9286 22.9276 29.3333 19.5362 29.3333 16C29.3333 12.4638 27.9286 9.07239 25.4281 6.57191C22.9276 4.07142 19.5362 2.66667 16 2.66667Z"
                fill="#fff"
              />
            </svg>
          </button>
        )}
      </div>
    </div>
  </div>
</footer>

{showThemeToggle && (
  <script is:inline>
    document.getElementById("footer-theme-toggle")?.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
  </script>
)}
