<!-- Search trigger (placed in Nav) -->
<button
  id="search-trigger"
  class="inline-flex items-center gap-2 shrink-0 px-2.5 py-1.5 text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-wider text-[var(--color-muted)] hover:text-[var(--color-fg)] transition-colors cursor-pointer group"
  aria-label="Search specification"
>
  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="8"/>
    <path d="m21 21-4.3-4.3"/>
  </svg>
  <span class="hidden sm:inline-flex items-center gap-1 text-[10px] text-[var(--color-muted)] opacity-60 group-hover:opacity-100 transition-opacity">
    <kbd class="inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 border border-[var(--color-border)] text-[9px] leading-none">⌘</kbd>
    <kbd class="inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 border border-[var(--color-border)] text-[9px] leading-none">K</kbd>
  </span>
</button>
